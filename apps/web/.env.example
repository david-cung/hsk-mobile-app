# Copy to `.env` or `.env.local` in apps/web for local development.
# Vite only exposes variables prefixed with VITE_ to client code.

# FastAPI backend base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# Mock API responses in dev without a running backend (MSW).
# Set to "true" to enable, "false" or omit to use the real API.
# Restart `npm run dev` after changing this value.
VITE_ENABLE_MSW=false
